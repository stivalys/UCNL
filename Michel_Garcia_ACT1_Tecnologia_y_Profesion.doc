\pard\qc\b\fs28 Tendencias de las aduanas y el comercio al año 2030\b0\fs24\par\par
\pard\qc Michel Garcia Garcia\par
\pard\qc Materia: Tecnolog\'eda y Profesion\par
\pard\qc Maestro: Alberto Daniel Salinas Montemayor\par
